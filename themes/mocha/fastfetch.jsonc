{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/dog.txt",
    "color": {
      "1": "bright_cyan"
    }
  },

  "display": {
    "separator": " "
  },

  "modules": [
    {
      "type": "custom",
      "format": "\u001b[94m      ╭─ SYSTEM ───────────────────────────────╮"
    },

    {
      "type": "os",
      "key": "      OS",
      "keyColor": "bright_cyan"
    },

    {
      "type": "kernel",
      "key": "      Kernel",
      "keyColor": "bright_cyan"
    },

    {
      "type": "host",
      "key": "      Host",
      "keyColor": "bright_cyan"
    },

    {
      "type": "uptime",
      "key": "      Uptime",
      "keyColor": "bright_cyan"
    },

    {
      "type": "custom",
      "format": "\u001b[94m      ╰────────────────────────────────────────╯"
    },

    {
      "type": "custom",
      "format": ""
    },

    {
      "type": "custom",
      "format": "\u001b[95m      ╭─ HARDWARE ─────────────────────────────╮"
    },

    {
      "type": "cpu",
      "key": "      CPU",
      "keyColor": "bright_red"
    },

    {
      "type": "gpu",
      "key": "      GPU",
      "keyColor": "bright_blue"
    },

    {
      "type": "memory",
      "key": "      Memory",
      "keyColor": "bright_magenta"
    },

    {
      "type": "disk",
      "key": "      Disk",
      "keyColor": "bright_green"
    },

    {
      "type": "custom",
      "format": "\u001b[95m      ╰────────────────────────────────────────╯"
    },

    {
      "type": "custom",
      "format": ""
    },

    {
      "type": "custom",
      "format": "\u001b[93m      ╭─ MISC ─────────────────────────────────╮"
    },

    {
      "type": "shell",
      "key": "      Shell",
      "keyColor": "bright_yellow"
    },

    {
      "type": "terminal",
      "key": "      Terminal",
      "keyColor": "bright_yellow"
    },

    {
      "type": "wm",
      "key": "      WM",
      "keyColor": "bright_yellow"
    },

    {
      "type": "packages",
      "key": "      Packages",
      "keyColor": "bright_yellow"
    },

    {
      "type": "locale",
      "key": "      Locale",
      "keyColor": "bright_yellow"
    },

    {
      "type": "custom",
      "format": "\u001b[93m      ╰────────────────────────────────────────╯"
    }
  ]
}